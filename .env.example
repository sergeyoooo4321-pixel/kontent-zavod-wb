# Пример конфигурации. Скопируй в .env и подставь реальные значения.
# .env коммитить НЕЛЬЗЯ.

# ── Telegram ─────────────────────────────────────────
TG_BOT_TOKEN=your-bot-token-here
TG_API_BASE=https://api.telegram.org

# ── AI-провайдер: aitunnel.ru (OpenAI-совместимый, ключ sk-aitunnel-...) ──
AITUNNEL_BASE=https://api.aitunnel.ru/v1
AITUNNEL_API_KEY=sk-aitunnel-xxx
AITUNNEL_IMAGE_MODEL=gpt-image-2
AITUNNEL_LLM_MODEL=gemini-3.1-pro-preview
AITUNNEL_LLM_FALLBACK_MODEL=claude-sonnet-4.6
AITUNNEL_POLL_INTERVAL_SEC=5
AITUNNEL_POLL_MAX_ATTEMPTS=60

# Backward-compat (старые KIE_* — сохранены для миграции, не используются)
KIE_BASE=https://api.kie.ai
KIE_API_KEY=
KIE_IMAGE_MODEL=gpt-image-2
KIE_LLM_MODEL=gemini-3.1-pro-preview
KIE_POLL_INTERVAL_SEC=5
KIE_POLL_MAX_ATTEMPTS=60

# ── Yandex Object Storage (S3-совместимое) ───────────
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=cz-content-zavod-prod
S3_ACCESS_KEY=your-access-key-here
S3_SECRET_KEY=your-secret-key-here
S3_PUBLIC_BASE=https://storage.yandexcloud.net/cz-content-zavod-prod

# ── Маркетплейсы ─────────────────────────────────────
OZON_BASE=https://api-seller.ozon.ru
WB_BASE=https://content-api.wildberries.ru

# Кабинеты Ozon + WB. Каждый кабинет — пара (Ozon Client-Id + Api-Key) + WB JWT.
# Бот в TG показывает кнопки выбора кабинета: Профит / Прогресс 24 / Прогресс 247 / ТНП.
# Для mirror-режима «🔄 Все сразу» одна и та же карточка заливается во все
# настроенные кабинеты одним прогоном.
# Если у кабинета только WB (как progress247) — ozon-стороны нет, заливается только WB.

# Профит
OZON_PROFIT_CLIENT_ID=
OZON_PROFIT_API_KEY=
WB_PROFIT_TOKEN=

# Прогресс 24
OZON_PROGRESS24_CLIENT_ID=
OZON_PROGRESS24_API_KEY=
WB_PROGRESS24_TOKEN=

# Прогресс 247 (только WB)
OZON_PROGRESS247_CLIENT_ID=
OZON_PROGRESS247_API_KEY=
WB_PROGRESS247_TOKEN=

# ТНП
OZON_TNP_CLIENT_ID=
OZON_TNP_API_KEY=
WB_TNP_TOKEN=

# Backward-compat: один безымянный кабинет «default» — на случай если придут
# старые скрипты с этими переменными. Если заданы любые именованные кабинеты выше —
# default нужен только как fallback.
OZON_CLIENT_ID=
OZON_API_KEY=
WB_TOKEN=

# ── Параллелизм / runtime ────────────────────────────
MAX_PARALLEL_PRODUCTS=3
HTTP_TIMEOUT_SEC=60
LLM_TEMPERATURE=0.2
LOG_LEVEL=INFO

# DRY_RUN=true — этапы 2-5 идут полностью (категории, тексты, атрибуты, маппинг),
# но в WB/Ozon ничего не отправляется: собранный payload приходит в TG как
# JSON-документ. Безопасно тестировать с боевыми токенами.
# DRY_RUN=false — реальная заливка карточек на маркетплейсы.
DRY_RUN=true

# ── Внутренний токен между n8n и Python (опц.) ───────
INTERNAL_TOKEN=
